{
	"name": "root",
	"private": true,
	"packageManager": "pnpm@10.26.2",
	"engines": {
		"node": "24.13.0"
	},
	"scripts": {
		"dev": "pnpm --parallel dev",
		"build": "pnpm --filter effectengine build && pnpm --filter web build",
